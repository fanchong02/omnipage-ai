# 测试目标站点（启动时输入 URL 会自动覆盖为对应 origin）
E2E_BASE_URL=http://localhost:3000

# 自动登录凭据（未在终端输入时从此读取；优先级低于 --email / --password）
E2E_EMAIL=
E2E_PASSWORD=

# 本地默认可视化浏览器；CI 请设 HEADLESS=true
# HEADLESS=false

# 可视化模式下每步操作延迟（毫秒），默认 300
# QA_SLOW_MO=300

# ── AI 截图分析 / 启发式逐步思考（explore、scan、autogen）──
# 复制本文件为 .env 并填写 API Key：
#   cp .env.example .env
QA_LLM_API_KEY=
QA_LLM_BASE_URL=https://api.openai.com/v1
QA_LLM_MODEL=gpt-4o-mini
# 截图视觉分析模型（需支持 image）；默认同 QA_LLM_MODEL
QA_LLM_VISION_MODEL=gpt-4o-mini
